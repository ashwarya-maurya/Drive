<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register — Drive</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            blue:   '#3772ff',
            green:  '#9fd356',
            dark:   '#0a0908',
            light:  '#fafffd',
            orange: '#fa824c',
          }
        }
      }
    }
  </script>
</head>

<body class="min-h-screen bg-dark flex items-center justify-center px-4">

  <div class="w-full max-w-sm">

    <!-- Brand -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-blue bg-opacity-20 mb-4">
        <i class="fa-brands fa-dropbox text-blue text-2xl"></i>
      </div>
      <h1 class="text-light text-2xl font-bold">Create account</h1>
      <p class="text-light text-opacity-40 text-sm mt-1">Your personal cloud drive</p>
    </div>

    <!-- Card -->
    <div class="border border-white border-opacity-10 rounded-2xl p-7">
      <form action="/user/register" method="post" class="space-y-5">

        <!-- Username -->
        <div>
          <label class="block text-light text-opacity-50 text-xs font-medium uppercase tracking-widest mb-2">
            <i class="fa-solid fa-user mr-1"></i> Username
          </label>
          <input
            type="text"
            name="username"
            placeholder="choose_a_username"
            autocomplete="new-password"
            class="w-full bg-black bg-opacity-20 border border-white border-opacity-10 text-light text-sm rounded-xl px-4 py-3 placeholder-white placeholder-opacity-20 focus:outline-none focus:border-blue focus:ring-2 focus:ring-blue focus:ring-opacity-20"
            required
          />
        </div>

        <!-- Email -->
        <div>
          <label class="block text-light text-opacity-50 text-xs font-medium uppercase tracking-widest mb-2">
            <i class="fa-solid fa-envelope mr-1"></i> Email
          </label>
          <input
            type="email"
            name="email"
            placeholder="you@example.com"
            class="w-full bg-black bg-opacity-20 border border-white border-opacity-10 text-light text-sm rounded-xl px-4 py-3 placeholder-white placeholder-opacity-20 focus:outline-none focus:border-blue focus:ring-2 focus:ring-blue focus:ring-opacity-20"
            required
          />
        </div>

        <!-- Password -->
        <div>
          <label class="block text-light text-opacity-50 text-xs font-medium uppercase tracking-widest mb-2">
            <i class="fa-solid fa-lock mr-1"></i> Password
          </label>
          <input
            type="password"
            name="password"
            placeholder="Min. 5 characters"
            class="w-full bg-black bg-opacity-20 border border-white border-opacity-10 text-light text-sm rounded-xl px-4 py-3 placeholder-white placeholder-opacity-20 focus:outline-none focus:border-blue focus:ring-2 focus:ring-blue focus:ring-opacity-20"
            required
          />
        </div>

        <button
          type="submit"
          class="w-full bg-blue hover:bg-opacity-90 text-light font-semibold text-sm py-3 rounded-xl"
        >
          <i class="fa-solid fa-user-plus mr-2"></i> Create Account
        </button>

      </form>
    </div>

    <p class="text-center mt-5 text-sm text-light text-opacity-40">
      Already have an account?
      <a href="/user/login" class="text-green font-medium hover:underline ml-1">
        <i class="fa-solid fa-right-to-bracket mr-1"></i>Sign in
      </a>
    </p>

  </div>

</body>
</html>
