<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Drive</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            blue:   '#3772ff',
            green:  '#9fd356',
            dark:   '#0a0908',
            light:  '#fafffd',
            orange: '#fa824c',
          }
        }
      }
    }
  </script>
  <style>
    ul::-webkit-scrollbar { width: 4px; }
    ul::-webkit-scrollbar-track { background: transparent; }
    ul::-webkit-scrollbar-thumb { background: #3772ff; border-radius: 999px; }
  </style>
</head>

<body class="min-h-screen bg-dark text-light">

  <!-- Navbar -->
  <nav class="border-b border-white border-opacity-10 px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <i class="fa-brands fa-dropbox text-blue text-xl"></i>
      <span class="text-light font-bold text-base">Drive</span>
    </div>
    <div class="flex items-center gap-4">
      <span class="bg-blue bg-opacity-15 text-blue text-xs font-semibold px-3 py-1 rounded-full">
        <i class="fa-solid fa-circle-user mr-1"></i><%= username %>
      </span>
      <a href="/user/logout" style="color:#df2935" class="text-sm hover:opacity-80">
        <i class="fa-solid fa-right-from-bracket mr-1"></i>Logout
      </a>
    </div>
  </nav>

  <!-- Main -->
  <main class="max-w-2xl mx-auto px-4 py-10 space-y-6">

    <!-- Upload Card -->
    <div class="border border-white border-opacity-10 rounded-2xl p-6">

      <h2 class="text-light font-semibold text-base mb-1">
        <i class="fa-solid fa-cloud-arrow-up text-blue mr-2"></i>Upload a File
      </h2>
      <p class="text-light text-opacity-40 text-sm mb-5 ml-6">Drop any file to store it in your drive</p>

      <form action="/upload" method="POST" enctype="multipart/form-data" id="uploadForm">

        <!-- Drop Zone -->
        <div
          id="uploadZone"
          onclick="document.getElementById('fileInput').click()"
          class="border-2 border-dashed border-white border-opacity-10 hover:border-blue hover:border-opacity-60 rounded-xl p-10 text-center cursor-pointer"
        >
          <!-- Default -->
          <div id="zoneDefault">
            <i class="fa-solid fa-cloud-arrow-up text-4xl text-light opacity-20 mb-3 block"></i>
            <p class="text-light text-sm font-medium">Click to browse or drag & drop</p>
            <p class="text-light text-opacity-30 text-xs mt-1">Any file type supported</p>
          </div>

          <!-- File selected -->
          <div id="zoneSelected" class="hidden">
            <i class="fa-solid fa-circle-check text-4xl text-green mb-3 block"></i>
            <p id="selectedName" class="text-light text-sm font-medium"></p>
            <p id="selectedSize" class="text-light text-opacity-30 text-xs mt-1"></p>
          </div>

          <input type="file" name="file" id="fileInput" class="hidden" required />
        </div>

        <button
          type="submit"
          id="uploadBtn"
          disabled
          class="w-full mt-4 py-3 rounded-xl text-sm font-semibold text-light bg-blue hover:bg-opacity-90 disabled:opacity-30 disabled:cursor-not-allowed"
        >
          <i class="fa-solid fa-upload mr-2"></i>Upload File
        </button>

      </form>
    </div>

    <% 
      const colors = ['text-blue', 'text-green', 'text-orange'];
      const randomColor = colors[Math.floor(Math.random() * colors.length)];
    %>
    <!-- Files Card -->
    <div class="border border-white border-opacity-10 rounded-2xl overflow-hidden">

      <!-- Header -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-white border-opacity-10">
        <h2 class="text-light font-semibold text-base">
          <i class="fa-solid fa-folder-open text-orange mr-2"></i>Your Files
        </h2>
        <span class="bg-orange bg-opacity-15 text-orange text-xs font-semibold px-3 py-1 rounded-full">
          <%= files.length %> file<%= files.length !== 1 ? 's' : '' %>
        </span>
      </div>

      <!-- Empty state -->
      <% if (files.length === 0) { %>
        <div class="py-8 text-center">
          <i class="fa-solid fa-folder-open text-4xl text-light opacity-10 mb-3 block"></i>
          <p class="text-light text-opacity-30 text-sm">No files uploaded yet</p>
        </div>

      <% } else { %>
        <ul class="overflow-y-auto max-h-36">
          <% files.forEach(file => {
            const displayName = file.name.replace(/^\d+_/, '');
            const ext = displayName.split('.').pop().toLowerCase();

            const sizeText = file.metadata && file.metadata.size
              ? file.metadata.size >= 1048576
                ? (file.metadata.size / 1048576).toFixed(1) + ' MB'
                : (file.metadata.size / 1024).toFixed(1) + ' KB'
              : '—';

          %>
            <li class="flex items-center justify-between px-6 py-4 border-b border-white border-opacity-5 last:border-b-0 hover:bg-white hover:bg-opacity-5">

              <div class="flex items-center gap-4 min-w-0">
                <div class="w-9 h-9 rounded-lg bg-white bg-opacity-5 flex items-center justify-center shrink-0">
                  <i class="fa-solid fa-file text-blue"></i>
                </div>
                <div class="min-w-0">
                  <p class="text-light text-sm font-medium truncate" style="max-width:280px" title="<%= displayName %>">
                    <%= displayName %>
                  </p>
                  <p class="text-light text-opacity-30 text-xs mt-0.5">
                    <%= ext.toUpperCase() %> &middot; <%= sizeText %>
                  </p>
                </div>
              </div>

              
              <a href="/download/<%= userId %>/<%= file.name %>"
                class="shrink-0 ml-4 bg-green bg-opacity-15 hover:bg-opacity-25 text-green text-xs font-semibold px-4 py-2 rounded-lg"
              >
                <i class="fa-solid fa-download mr-1"></i>Download
              </a>

            </li>
          <% }) %>
        </ul>
      <% } %>

    </div>
  </main>

<script>
  const zone    = document.getElementById('uploadZone');
  const input   = document.getElementById('fileInput');
  const btn     = document.getElementById('uploadBtn');
  const defView = document.getElementById('zoneDefault');
  const selView = document.getElementById('zoneSelected');
  const selName = document.getElementById('selectedName');
  const selSize = document.getElementById('selectedSize');

  function formatSize(bytes) {
    if (bytes >= 1048576) return (bytes / 1048576).toFixed(1) + ' MB';
    return (bytes / 1024).toFixed(1) + ' KB';
  }

  function showFile(file) {
    defView.classList.add('hidden');
    selView.classList.remove('hidden');
    zone.classList.remove('border-opacity-10');
    zone.classList.add('border-green', 'border-opacity-50');
    selName.textContent = file.name;
    selSize.textContent = formatSize(file.size);
    btn.disabled = false;
  }

  input.addEventListener('change', () => {
    if (input.files[0]) showFile(input.files[0]);
  });

  zone.addEventListener('dragover', (e) => {
    e.preventDefault();
    zone.classList.add('border-blue', 'border-opacity-60');
  });

  zone.addEventListener('dragleave', () => {
    zone.classList.remove('border-blue', 'border-opacity-60');
  });

  zone.addEventListener('drop', (e) => {
    e.preventDefault();
    zone.classList.remove('border-blue', 'border-opacity-60');
    const files = e.dataTransfer.files;
    if (files[0]) {
      input.files = files;
      showFile(files[0]);
    }
  });

  document.getElementById('uploadForm').addEventListener('submit', () => {
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>Uploading...';
    btn.disabled = true;
  });
</script>

</body>
</html>
